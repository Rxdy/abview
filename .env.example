# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3333/oauth2callback

# Google Tokens (obtained via server/scripts/get_token.ts)
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_ACCESS_TOKEN=your-access-token

# Google Photos Picker Session ID
# Set after running server/scripts/setup_photos_picker.ts
GOOGLE_PICKER_SESSION_ID=your-picker-session-id

# Weather API
OPENWEATHER_API_KEY=your-openweather-api-key

# App Configuration
APP_KEY=your-app-encryption-key

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app

# UI Configuration
VITE_SCREEN_OFF_START=23
VITE_SCREEN_OFF_START_MINUTES=0
VITE_SCREEN_OFF_END=7
VITE_SCREEN_OFF_END_MINUTES=0
