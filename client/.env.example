# API Configuration
# En développement : utilise le proxy Vite (/api -> localhost:3333)
# En production : configure l'URL complète si différente de la racine
VITE_API_URL=

# Délai d'inactivité avant activation du screensaver (en millisecondes)
# Défaut : 180000 (3 minutes)
VITE_IDLE_TIMEOUT_MS=180000