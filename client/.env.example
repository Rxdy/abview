# API Configuration
# En développement : utilise le proxy Vite (/api -> localhost:3333)
# En production : configure l'URL complète si différente de la racine
VITE_API_URL=

# ── AbFlow (source de photos pour le screensaver) ─────────────
# URL complète du backend AbFlow (ex: http://192.168.1.x:3000)
# Laisser vide pour désactiver et utiliser Google Photos à la place.
VITE_ABFLOW_URL=
# Clé API générée dans AbFlow (.env API_KEY)
VITE_ABFLOW_API_KEY=

# Délai d'inactivité avant activation du screensaver (en millisecondes)
# Défaut : 180000 (3 minutes)
VITE_IDLE_TIMEOUT_MS=180000